<%- include("partials/header.ejs") %>

<main class="py-5">
  <div class="container">
    <div class="row">
      <div class="col-md-12">

        <div class="card index_page">

          <!-- card header -->
          <div class="card-header card-title">
            <div class="d-flex align-items-center justify-content-between">
              <h2>All contact</h2>

              <a href="/add-contact" class="btn btn-success">
                <i class="fa fa-plus-circle me-2"></i>
                Add New
              </a>
            </div>
          </div>

          <!-- card body -->
          <div class="card-body">

            <table class="table table-striped table-hover">

              <thead>
                <tr>
                  <th>Sr. No.</th>
                  <th>First Name</th>
                  <th>Last Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Actions</th>
                </tr>
              </thead>

              <tbody>

                <% contacts.forEach((contact,index)=>{ %>

                  <tr>
                    <td><%= index + 1 %></td>
                    <td><%= contact.first_name %></td>
                    <td><%= contact.last_name %></td>
                    <td><%= contact.email %></td>
                    <td><%= contact.phone %></td>

                    <td>

                      <a href="/show-contact/<%=contact._id%>" class="btn btn-outline-info btn-sm btn-rounded" title="Show">
                        <i class="fa fa-eye"></i>
                      </a>

                   <a href="/update-contact/<%=contact._id%>" class="btn btn-outline-secondary btn-sm btn-rounded" title="Edit">
                        <i class="fa fa-edit"></i>
                      </a>

                      <a href="/delete-contact/<%=contact._id%>"class="btn btn-outline-danger btn-sm btn-rounded" title="Delete">
                        <i class="fa fa-remove"></i>
                      </a>

                    </td>
                  </tr>

                <% }) %>

              </tbody>

            </table>

          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include("partials/footer.ejs") %>